programa {
  funcao inicio() {
    real altura_do_degrau, degraus_necessarios,altura_desejada
    escreva("altura_do_degrau","\n") escreva("altura desejada","\n")
    leia(altura_do_degrau) leia(altura_desejada)
    degraus_necessarios=altura_desejada/altura_do_degrau
    escreva("degraus necessarios e", degraus_necessarios)

  }
}
