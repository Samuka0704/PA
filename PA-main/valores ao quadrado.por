programa {
  funcao inicio() {
    real valor1, valor2, valor3, soma_dos_valores_ao_quadrado
    escreva("valor1") escreva("valor2") escreva("valor3" )
    leia(valor1) leia(valor2) leia(valor3)
    soma_dos_valores_ao_quadrado=(valor1*valor1)+(valor2*valor2)+(valor3*valor3)
    escreva("a soma dos quadrados e",soma_dos_valores_ao_quadrado)

  }
}
